{
  "name": "ash",
  "productName": "Ash",
  "version": "0.3.0",
  "private": true,
  "description": "Ash — fully local photo gallery: drag-drop photos, described on-device by local models (llama.cpp), search/filter/connect via khora (embedded, offline).",
  "main": "electron/main.js",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "setup:win": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "binaries": "node scripts/fetch-binaries.mjs",
    "install-app": "node scripts/make-macos-app.mjs",
    "start": "electron ."
  },
  "devDependencies": {
    "electron": "^33.2.0"
  }
}
